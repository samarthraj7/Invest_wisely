# ============================================================
# Invest Wisely - environment configuration (TEMPLATE)
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# Leave a key blank or as a placeholder to run that step in MOCK mode.
# ============================================================

# ---- LLM: Anthropic Claude ----
ANTHROPIC_API_KEY=PLACEHOLDER_ANTHROPIC_API_KEY
# Pick a model your account can access (GET https://api.anthropic.com/v1/models)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Web search / research: Exa ----
EXA_API_KEY=PLACEHOLDER_EXA_API_KEY

# ---- People enrichment: Proxycurl (LinkedIn-style profiles) ----
PROXYCURL_API_KEY=PLACEHOLDER_PROXYCURL_API_KEY

# ---- App config ----
# When true (default if any key is a placeholder), pipeline returns
# deterministic mock research/analysis so you can run end-to-end with no keys.
ALLOW_MOCK_MODE=true

# Research cache TTL in days (avoids re-billing repeat person/company lookups)
RESEARCH_CACHE_TTL_DAYS=30

# ---- OCR (image-only / scanned PDF decks) ----
# Recovers text from decks that are mostly images (e.g. design-heavy decks).
# Runs ONLY on pages that have images but little/no selectable text.
#   auto      -> local Tesseract if installed, else Claude vision (recommended)
#   vision    -> always Claude vision (uses ANTHROPIC_API_KEY; no install needed)
#   tesseract -> only local Tesseract (free; see requirements-optional.txt)
#   off       -> disable OCR
OCR_ENGINE=auto
OCR_MAX_PAGES=20            # cost guard: max pages OCR'd per deck
OCR_MIN_CHARS_PER_PAGE=30   # a page below this (with images) is an OCR candidate

# SQLite DB path (relative to backend/)
DATABASE_URL=sqlite:///./storage/invest_wisely.sqlite3

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# ---- Frontend ----
# Base URL the Next.js app uses to reach the FastAPI backend
NEXT_PUBLIC_API_BASE=http://localhost:8000
